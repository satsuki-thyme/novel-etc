                    "color": "#ffc851"
                }
            ]
        },
        // その他
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)((?!.*ない)ない|(?!が|た|だ)(?!。|、|「|『|〈|《|（|」|』|〉|》|）|！?？|？?！)\\p{scx=Hira})(?=[―…ー]*(。|、|「|『|〈|（|」|』|〉|）|！?？|？?！|―|\\n|$))": {
