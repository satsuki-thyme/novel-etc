   ## ##     ## ##      ##    ## ##     ## ##     ## ##     ## ##       ##   ###    ##    
   ## ##     ## ##       ######   #######  ##     ## ##     ## ######## ##    ##    ##    
*/
        /*

            コメントイン

        */
        // 
        "(activity:|dn:|tone:|pre-action:|action:|narration in beat:|reaction:|post-reaction:)": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "decorations": [
                {
                    "color": "#f52929",
                    "opacity": "1"
                }
            ]
        },
        // ハイフン
        "(?<!\\.|-|\\w)(-)(?!.*:|-|\\w)": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "decorations": [
                {
                    "color": "#f52929",
                    "opacity": "1"
                }
            ]
        },
        /*

            コメントアウト

        */
        // beat をさらに暗く
        "^(beat)": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gm",
            "decorations": [
                {
                    "opacity": "0.1"
                }
            ]
        },
        // 本文中の.以下を暗転
        "(^[ \\t]*\\..*)": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gm",
            "decorations": [
                {
                    "color": "#799dc5"
                }
            ]
        },
        // 本文中の#以下を暗転
        "(^[ \\t]*#.*)": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gm",
            "decorations": [
                {
                    "opacity": "0.43"
                }
            ]
        },
        // 本文中の半角スペース後を暗転
        "(^[ \\t]+(?!activity:|pf-dn:|tone:).*|- (?!.*:).*)": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gm",
            "decorations": [
                {
                    "opacity": "0.43"
                }
            ]
        },
        // 本文中のプロット記法を暗転
