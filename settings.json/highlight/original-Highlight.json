    "highlight.regexes": {
        // 不具合対応
        "(.)$": {
            "filterLanguageRegex": "text|markdown|yaml",
            "regexFlags": "gm",
            "decorations": [
                {}
            ]
        },
/* # text
   ## ##      ######## ######## ##     ## ######## 
   ## ##         ##    ##        ##   ##     ##    
 #########       ##    ##         ## ##      ##    
   ## ##         ##    ######      ###       ##    
 #########       ##    ##         ## ##      ##    
   ## ##         ##    ##        ##   ##     ##    
   ## ##         ##    ######## ##     ##    ##    
*/
        // 全角スペース
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)(　)": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gm",
            "decorations": [
                {
                    "border": "1px solid #7c6825"
                }
            ]
        },
        // notice: 特に接近に注意したい語
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)((?<!(?!。|、|「|『|〈|《|（|」|』|〉|》|）|！?？|？?！)\\p{scx=Han})(姿|様子|面持ち|面立ち|様相|形相|人相|容姿|気配|様|態度|顔([付つ]き)?|表情|顔貌|容貌|風貌|相貌|面差し|面相|面容|面貌|面影|満面|相好|顔立ち|容相|美容|美相|美貌|美顔|麗容|顔面|目|瞳|眼|視線|視界|目差し|双眸|目[付つ]き|目差|眼差|眼光|笑|苦笑|微笑|笑顔)(?!(?!《)\\p{scx=Han}))": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gum",
            "decorations": [
                {
                    "color": "#f888f2"
                }
            ]
        },
        // notice: となっている、となっていた
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)((?<=に|と)なってい(?=る|た))(?=[―…ー]*(。|、|「|『|〈|《|（|」|』|〉|》|）|！?？|？?！|―|\\n|$))": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gm",
            "decorations": [
                {
                    "color": "#f888f2"
                }
            ]
        },
        // notice: という
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)((?<!だ)という(?!のに)|(?<!だ)という|という(?!のに))(?=こと|の|もの|わけ|(?!。|、|「|『|〈|《|（|」|』|〉|》|）|！?？|？?！)\\p{scx=Han})": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gum",
            "decorations": [
                {
                    "color": "#f888f2"
                }
            ]
        },
        // notice: すること（サ変名詞に「～すること」）
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)(すること)": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gm",
            "decorations": [
                {
                    "color": "#f888f2"
                }
            ]
        },
        // notice: ほど
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)((?<!(?<!\\p{scx=Han})さ|よ)ほど(?=[がだでにのはへを]|\\p{scx=Han}))": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gum",
            "decorations": [
                {
                    "color": "#f888f2"
                }
            ]
        },
        // notice: よう（な）
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)(((?<![いきしちにひみり]|\\p{scx=Han}[えけせてねへめれ])よう(?!\\p{scx=Han})|ごと[くきし]|みたい))": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gum",
            "decorations": [
                {
                    "color": "#f888f2"
                }
            ]
        },
        // notice: らし（い）
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)((らし)(?=い|かった|き|く｜けれ))": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gm",
            "decorations": [
                {
                    "color": "#f888f2"
                }
            ]
        },
        // notice: まるで
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)(まるで)": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gm",
            "decorations": [
                {
                    "color": "#f888f2"
                }
            ]
        },
        // notice: 逆接の接続詞
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)(?<!｜[^》]*?)((?<=い|た|だ|う|く|ぐ|す|つ|ぬ|ぶ|む|る)((?<!あっち|こっち|さす|そっち|どっち|ほう|すがす|\\p{scx=Han}.{0,2}い|向こう)が(?!すが)|(?<!はずだ|んだ)けど)|(?<!も)しかし(?!て)|(?<!も)しかし|しかし(?!て)|それでも|だが|(?<!はず|ん)だけど|(?<!と|なん|何|わけ|ワケ|\\p{scx=Han}[いん])でも|(とは)?[い言]え(?!ない)(ども?)?|にも(｜拘《かかわ》|かかわ)らず|他方で?|一方(?!的|向(?![かきくけ]))|方や|(?<!\\p{scx=Han}||\\p{scx=Han}.{0,2}い)も(?!しな|でき|の)|ものの)(?![^｜]*》)": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gum",
            "decorations": [
                {
                    "color": "#f888f2"
                }
            ]
        },
        // notice: ことができる、ことができない
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)((?<=う|く|す|つ|ぬ|ふ|む|ゆ|る)ことができ(?=[たる])|(?<=う|く|す|つ|ぬ|ふ|む|ゆ|る)ことができな(い|かった))": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gm",
            "decorations": [
                {
                    "color": "#f888f2"
                }
            ]
        },
        // 基本形
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)(?<=\\p{scx=Han}.*)((?<!しょ|そ|よ|ろ)う|く|ぐ|す|つ|ぬ|ぶ|む|る)(?=[―…ー]*(。|、|「|『|〈|（|」|』|〉|）|！?？|？?！|―|\\n|$))": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gum",
            "decorations": [
                {
                    "color": "#88f882"
                }
            ]
        },
        // タ形
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)(た|(?<=\\p{scx=Han}(?!.*くらい|.*の|.*ばかり|.*ふう|.*みたい|.*もの|.*よう|.[きｋ].*[えけせてねへめれ])\\p{scx=Hira}{0,2}[いん]|\\p{scx=Han}(?!.*くらい|.*の|.*ばかり|.*ふう|.*みたい|.*もの|.*よう|.*[いきしちにひみいり]|.*[えけせてねへめれ])\\p{scx=Hira}{1,3}|(?!.*くらい|.*の|.*ばかり|.*ふう|.*みたい|.*もの|.*よう|.*[いきしちにひみいり]|.*[えけせてねへめれ])\\p{scx=Hira}{3,})(?<!\\p{scx=Han}|\\p{scx=Kana}|くらい|の|ばかり|ふう|ほう|みたい|もの|よう|[いきしちにひみいり]|[えけせてねへめれ])(だ))(?=[―…ー]*(。|、|「|『|〈|（|」|』|〉|）|！?？|？?！|―|\\n|$))": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gum",
            "decorations": [
                {
                    "color": "#8888f2"
                }
            ]
        },
        // 断定の「だ」
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)(?<!\\p{scx=Han}(?!.*くらい|.*の|.*ばかり|.*ふう|.*みたい|.*もの|.*よう|.[きｋ].*[えけせてねへめれ])\\p{scx=Hira}{0,2}[いん]|\\p{scx=Han}(?!.*くらい|.*の|.*ばかり|.*ふう|.*みたい|.*もの|.*よう|.*[いきしちにひみいり]|.*[えけせてねへめれ])\\p{scx=Hira}{1,3}|(?!.*くらい|.*の|.*ばかり|.*ふう|.*みたい|.*もの|.*よう|.*[いきしちにひみいり]|.*[えけせてねへめれ])\\p{scx=Hira}{3,})(?<=\\p{scx=Han}|\\p{scx=Kana}|くらい|の|ばかり|ふう|ほう|みたい|もの|よう|ために|ように|[いきしちにひみいり]|[えけせてねへめれ])(だ)(?=[―…ー]*(。|、|「|『|〈|（|」|』|〉|）|！?？|？?！|―|\\n|$))": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gum",
            "decorations": [
                {
                    "color": "#f88882"
                }
            ]
        },
        // ない
        "(?<!^[ \\t]*[./$:-].*|(?!.*@).* .*)(ない)(?=[―…ー]*(。|、|「|『|〈|（|」|』|〉|）|！?？|？?！|―|\\n|$))": {
            "filterLanguageRegex": "text",
            "filterFileRegex": "tex-\\d{3}\\.txt",
            "regexFlags": "gum",
            "decorations": [
